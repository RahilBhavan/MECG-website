# Canonical public URL (no trailing slash). Used at build time for OG tags, canonical link, and Twitter cards.
# Example: https://your-domain.com
# VITE_SITE_URL="https://your-domain.com"

# --- Supabase (Auth + Postgres) ---
#
# Vercel: https://vercel.com/dashboard → your project → Settings → Integrations →
# "Browse Marketplace" → Supabase → Add integration → pick this Vercel project + your Supabase project.
# Marketplace sync often sets NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY,
# and sometimes SUPABASE_URL / SUPABASE_PUBLISHABLE_KEY (no NEXT_PUBLIC_). `vite.config.ts` maps
# those into the client at build time. You can still set VITE_SUPABASE_* manually in Vercel.
# Also set VITE_SITE_URL in Vercel (Production + Preview) to your deployed origin for OG tags.
#
# 1. Create a project: https://supabase.com/dashboard → New project (pick region, set DB password).
# 2. Project Settings → API: copy "Project URL" and "anon public" key into .env.local (not committed).
# 3. Link CLI and apply schema:
#    bunx supabase login
#    bunx supabase link --project-ref YOUR_PROJECT_REF
#    bunx supabase db push
#    (Or paste supabase/migrations/20260329000000_initial_schema.sql into SQL Editor → Run.)
# 4. Authentication → URL configuration:
#    Site URL: http://localhost:3000 (prod: https://your-app.vercel.app or custom domain)
#    Redirect URLs: include http://localhost:3000/reset-password and https://your-app.vercel.app/reset-password
# 5. Bootstrap admin: Dashboard → Authentication → Users → copy UUID, then SQL:
#    insert into public.user_roles (user_id, role) values ('YOUR_USER_UUID', 'admin') on conflict do nothing;
#
# Local stack (optional): bun run db:start → use Studio at http://127.0.0.1:54323 and keys from CLI output.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Optional: preset batch ids for /review dropdown (comma-separated). Merged with ids seen in `applications`.
# VITE_REVIEW_BATCH_IDS="default,w26"

# Optional: HTTPS URL that accepts small JSON beacons for Core Web Vitals (production builds only).
# VITE_WEB_VITALS_ENDPOINT="https://your-analytics.example.com/vitals"

# --- Observability (optional) ---
# VITE_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# VITE_SENTRY_DEV="true"
# VITE_PLAUSIBLE_DOMAIN="your-domain.com"
# VITE_PLAUSIBLE_SCRIPT_URL="https://plausible.io/js/script.js"
# VITE_ANALYTICS_EVENTS_ENDPOINT="https://your-backend.example.com/analytics/events"

# --- Playwright E2E (local / CI; never commit real passwords) ---
# E2E_APPLICANT_EMAIL="applicant@example.com"
# E2E_APPLICANT_PASSWORD="..."
# E2E_REVIEWER_EMAIL="reviewer@example.com"
# E2E_REVIEWER_PASSWORD="..."
# E2E_ALUMNI_EMAIL="alumni@example.com"
# E2E_ALUMNI_PASSWORD="..."
# E2E_ADMIN_EMAIL="admin@example.com"
# E2E_ADMIN_PASSWORD="..."
