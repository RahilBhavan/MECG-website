{
	"name": "mecg-website",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite --port=3000 --host=0.0.0.0",
		"build": "vite build",
		"check:bundle": "bun run scripts/check-bundle-budget.ts",
		"preview": "vite preview",
		"clean": "rm -rf dist",
		"lint": "tsc --noEmit && biome check .",
		"lint:fix": "biome check --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"playwright:install": "playwright install chromium",
		"og:generate": "bun run scripts/generate-og.ts",
		"db:types": "supabase gen types typescript --local > src/types/supabase.gen.ts",
		"roster:import": "bun run scripts/import-roster.ts",
		"db:start": "supabase start",
		"db:stop": "supabase stop",
		"db:reset": "supabase db reset",
		"db:push": "supabase db push"
	},
	"dependencies": {
		"@chenglou/pretext": "^0.0.3",
		"@fontsource/inter": "^5.2.8",
		"@fontsource/playfair-display": "^5.2.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.5.0",
		"@studio-freight/lenis": "^1.0.42",
		"@supabase/supabase-js": "^2.100.1",
		"@tailwindcss/vite": "^4.1.14",
		"@vitejs/plugin-react": "^5.0.4",
		"balloons-js": "^0.0.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dotenv": "^17.2.3",
		"gsap": "^3.14.2",
		"lucide-react": "^0.546.0",
		"motion": "^12.23.24",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-router-dom": "^7.13.2",
		"simple-icons": "^16.14.0",
		"tailwind-merge": "^3.5.0",
		"three": "^0.183.2",
		"vite": "^6.2.0",
		"web-vitals": "^5.2.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@playwright/test": "^1.58.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.5.0",
		"autoprefixer": "^10.4.21",
		"happy-dom": "^20.8.9",
		"sharp": "^0.34.5",
		"supabase": "^2.75.0",
		"tailwindcss": "^4.1.14",
		"tsx": "^4.21.0",
		"typescript": "~5.8.2",
		"vitest": "^4.1.2",
		"xlsx": "^0.18.5"
	}
}
